{
  "name": "code-review-helper-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate && prisma generate --schema prisma/workspace.schema.prisma",
    "db:generate:global": "prisma generate",
    "db:generate:workspace": "prisma generate --schema prisma/workspace.schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@openai/codex-sdk": "^0.128.0",
    "@prisma/client": "^6.16.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.4.0",
    "node-pty": "^1.1.0",
    "openai": "^6.35.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prisma": "^6.16.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
