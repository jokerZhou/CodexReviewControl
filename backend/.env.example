# 改动说明：DATABASE_URL 中的相对路径会被 Prisma 解析为「相对于 schema.prisma 所在目录」，
# 因此 file:./dev.db 实际指向 backend/prisma/dev.db（与 schema.prisma 同目录）。
# 不要写成 file:./prisma/dev.db，否则 CLI 会建出 backend/prisma/prisma/dev.db 嵌套目录，
# 导致 P2021（运行时连接的库与 CLI 建表的库不是同一个）。
DATABASE_URL="file:./dev.db"
HOST="0.0.0.0"
PORT="4000"
WEBSITE_ORIGIN="http://localhost:3000"
# 改动说明：可选，逗号分隔多个允许的前端来源（用于局域网/多网卡访问开发环境）。
# 示例：CORS_ALLOWED_ORIGINS="http://192.168.30.1:3000,http://192.168.31.137:3000"
CORS_ALLOWED_ORIGINS=""
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
