generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/workspace-client"
}

datasource db {
  provider = "sqlite"
  url      = env("WORKSPACE_DATABASE_URL")
}

enum AgentProvider {
  CODEX
  CODEX_CLI
  CURSOR
}

model Session {
  id                String        @id @default(cuid())
  name              String
  provider          AgentProvider
  externalSessionId String?
  workspaceId       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  messages Message[]
  turns    Turn[]
  researchPlans ResearchPlan[]

  @@index([workspaceId])
  @@index([provider])
  @@index([createdAt])
  @@index([deletedAt])
}

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String
  taskTitle String?
  sessionId String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  researchPlan ResearchPlan?

  @@index([sessionId])
  @@index([createdAt])
}

model ResearchPlan {
  id              String   @id @default(cuid())
  sessionId       String
  messageId       String   @unique
  prompt          String
  summary         String
  plannedFilesJson String
  createdAt       DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  turns   Turn[]

  @@index([sessionId])
  @@index([createdAt])
}

model Turn {
  id               String    @id @default(cuid())
  prompt           String
  taskTitle        String?
  assistantContent String?
  sessionId        String
  userMessageId    String?
  researchPlanId   String?
  plannedFilesJson String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  session       Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  researchPlan  ResearchPlan?      @relation(fields: [researchPlanId], references: [id], onDelete: SetNull)
  modifiedFiles ModifiedFile[]
  reviewNotes   ReviewChangeNote[]

  @@index([sessionId])
  @@index([researchPlanId])
  @@index([createdAt])
}

model ModifiedFile {
  id            String   @id @default(cuid())
  path          String
  kind          String
  beforeContent String?
  afterContent  String?
  content       String?
  scopeStatus   String?
  turnId        String
  createdAt     DateTime @default(now())

  turn Turn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([turnId])
  @@index([path])
}

model ReviewChangeNote {
  id        String   @id @default(cuid())
  turnId    String
  filePath  String
  groupId   String
  note      String
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  turn Turn @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@unique([turnId, filePath, groupId])
  @@index([turnId])
  @@index([filePath])
}
